<!doctype html>
<html lang="{{locale}}">
  <head>
    <meta charset="utf-8" />
    <title>{{page.title}} | {{siteName}}</title>
  </head>
  <body class="{{bodyClass}}">
    <header><nav>{{> mainNav}}</nav></header>
    <main>
      {{#each sections}}
      <section id="{{slug}}">
        <h2>{{title}}</h2>
        {{{body}}}
      </section>
      {{/each}}
    </main>
    <footer>
      {{#if showFooter}}
      <p>&copy; {{year}} {{siteName}}</p>
      {{/if}}
    </footer>
  </body>
</html>
